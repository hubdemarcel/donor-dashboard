generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  giftRows  GiftRow[]
  createdAt DateTime  @default(now())
}

model GiftRow {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  donor_id    String
  donor_name  String
  segment     String
  gift_date   String
  gift_amount Float
  campaign    String
  channel     String
  region      String
  city        String   @default("")
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, gift_date])
}
